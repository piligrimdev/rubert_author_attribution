global:
  scrape_interval: 15s

scrape_configs:
  - job_name: api-local
    metrics_path: /metrics
    static_configs:
      - targets: ["__API_METRICS_TARGET__"]
        labels:
          service: api

  - job_name: celery-worker
    metrics_path: /metrics
    static_configs:
      - targets: ["worker:8001"]
        labels:
          service: celery
